{
  "manifest_version": 3,
  "name": "Meet + Leexi (1-click)",
  "version": "1.3.0",
  "description": "Create a new Google Meet and instantly invite the Leexi note-taker bot — in one click.",
  "action": {
    "default_title": "New Meet + invite Leexi",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "scripting", "clipboardWrite", "storage"],
  "host_permissions": [
    "https://public-api.leexi.ai/*",
    "https://meet.google.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
